---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  current: string;
}

const {
  title,
  description = 'Marcin Sztukowski – MSc CS, Jagiellonian University. ML systems at the intersection of medicine, bioinformatics and hardware.',
  current,
} = Astro.props;

const nav = [
  { href: '/',         label: 'Home'     },
  { href: '/about',    label: 'About'    },
  { href: '/skills',   label: 'Skills'   },
  { href: '/projects', label: 'Projects' },
  { href: '/courses',  label: 'Courses'  },
  { href: '/hobby',    label: 'Hobby'    },
  { href: '/cv',       label: 'CV'       },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title === 'Home' ? 'Marcin Sztukowski' : `${title} · Marcin Sztukowski`}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body>

  <header class="topbar">
    <a href="/" class="topbar-logo">Marcin <span>Sztukowski</span></a>
    <nav class="topbar-nav">
      {nav.map(({ href, label }) => (
        <a href={href} class={current === href ? 'active' : ''}>
          {label}
        </a>
      ))}
    </nav>
  </header>

  <main class="wrapper">
    <slot />
  </main>

  <footer>
    <span>© 2025 Marcin Sztukowski</span>
    <a href="https://github.com/FBI223" target="_blank" rel="noopener">
      github.com/FBI223
    </a>
  </footer>

</body>
</html>
