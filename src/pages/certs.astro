---
import Layout from '../layouts/Layout.astro';

const certs = [
    {
        title: 'Cisco CCNA',
        issuer: 'Cisco',
        date: '2026',
        desc_en: 'Network fundamentals, IP connectivity & services, security basics, and network automation.',
        desc_pl: 'Podstawy sieciowe, łączność IP i usługi, bezpieczeństwo sieci oraz automatyzacja.',
        img: '/ccna.jpg',
        url: 'https://cp.certmetrics.com/cisco/en/public/verify/credential/f20d21724de541d8aa7372e1e40dc995',
        copyCode: null,
    },
    {
        title: 'English C1 Advanced',
        issuer: 'British Council · EnglishScore',
        date: '2026',
        desc_en: 'CEFR C1 Advanced · Score 538 · Verification code e5aca5c2009e .',
        desc_pl: 'CEFR C1 Advanced · Wynik 538 · Kod weryfikacji e5aca5c2009e.',
        img: '/english_score.png',
        url: 'https://englishscore.com/verify',
        copyCode: 'e5aca5c2009e',
    },
    {
        title: 'Forklift Operator Licence (WJO)',
        issuer: 'UDT',
        date: '2020',
        desc_en: 'Certificate of authorisation to operate forklift trucks — UDT licence category II WJO.',
        desc_pl: 'Zaświadczenie kwalifikacyjne do obsługi wózków jezdniowych — licencja UDT kategorii II WJO.',
        img: '/forklift.png',
        url: '/2_wjo_cert.pdf',
        copyCode: null,
    },
];
---

<Layout title="Certs" current="/certs/">
    <style>
        .page-header {
            padding: 2.5rem 0 2rem;
            border-bottom: 1px solid var(--border);
            margin-bottom: 2.5rem;
        }
        .page-eyebrow {
            font-family: var(--mono); font-size: 11px; color: var(--accent2);
            letter-spacing: 2.5px; text-transform: uppercase; margin-bottom: 0.75rem;
        }
        .page-header h1 {
            font-family: var(--mono); font-size: 36px; font-weight: 600;
            color: var(--text); letter-spacing: -1px; line-height: 1.1; margin-bottom: 0.75rem;
        }
        .page-header h1 span { color: var(--accent); }
        .page-sub {
            font-size: 14px; color: var(--muted); max-width: 560px; line-height: 1.75;
        }

        .certs-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 16px;
        }

        .cert-card {
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: var(--r2);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: border-color 0.15s, background 0.15s;
            text-decoration: none;
            cursor: pointer;
            position: relative;
        }
        .cert-card:hover { background: var(--bg3); border-color: var(--border2); }

        .cert-img-wrap {
            width: 100%;
            aspect-ratio: 16/9;
            background: var(--bg3);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border-bottom: 1px solid var(--border);
        }
        .cert-img-wrap img {
            width: 100%; height: 100%;
            object-fit: contain; padding: 1rem;
        }

        .cert-body {
            padding: 1.1rem 1.25rem 1.25rem;
            display: flex; flex-direction: column;
            gap: 4px; flex: 1;
        }
        .cert-issuer {
            font-family: var(--mono); font-size: 10px; color: var(--accent2);
            letter-spacing: 1.5px; text-transform: uppercase;
        }
        .cert-title {
            font-family: var(--mono); font-size: 14px; font-weight: 600;
            color: var(--text); margin: 2px 0 4px;
        }
        .cert-desc { font-size: 12px; color: var(--muted); line-height: 1.6; }

        .copy-badge {
            font-family: var(--mono); font-size: 9px; color: var(--accent2);
            background: rgba(34,217,122,0.07); border: 1px solid rgba(34,217,122,0.15);
            padding: 2px 8px; border-radius: 10px; margin-top: 2px;
            display: inline-block; width: fit-content;
        }

        .cert-footer {
            display: flex; align-items: center; justify-content: space-between;
            margin-top: auto; padding-top: 12px;
        }
        .cert-date { font-family: var(--mono); font-size: 10px; color: var(--muted); }
        .cert-link { font-family: var(--mono); font-size: 11px; color: var(--accent); }

        .toast {
            position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%);
            background: var(--accent); color: #000;
            font-family: var(--mono); font-size: 12px; font-weight: 600;
            padding: 10px 22px; border-radius: 20px;
            opacity: 0; pointer-events: none;
            transition: opacity 0.2s;
            z-index: 999;
            white-space: nowrap;
        }
        .toast.show { opacity: 1; }

        @media (max-width: 640px) {
            .page-header h1 { font-size: 26px; }
            .certs-grid { grid-template-columns: 1fr; }
        }
    </style>

    <div class="page-header">
        <div class="page-eyebrow">// credentials</div>
        <h1>My <span>Certificates</span></h1>
        <p class="page-sub"
           data-en="Industry certifications and credentials I have earned."
           data-pl="Certyfikaty branżowe i poświadczenia, które zdobyłem.">
            Industry certifications and credentials I have earned.
        </p>
    </div>

    <div class="certs-grid">
        {certs.map(cert => (
                <div
                        class="cert-card"
                        data-url={cert.url}
                        data-copy={cert.copyCode ?? ''}
                >
                    <div class="cert-img-wrap">
                        <img src={cert.img} alt={cert.title} />
                    </div>
                    <div class="cert-body">
                        <div class="cert-issuer">{cert.issuer}</div>
                        <div class="cert-title">{cert.title}</div>
                        <div class="cert-desc" data-en={cert.desc_en} data-pl={cert.desc_pl}>
                            {cert.desc_en}
                        </div>
                        {cert.copyCode && (
                                <div class="copy-badge">📋 code auto-copied on click</div>
                        )}
                        <div class="cert-footer">
                            <span class="cert-date">{cert.date}</span>
                            <span class="cert-link" data-en="View cert →" data-pl="Zobacz certyfikat →">View cert →</span>
                        </div>
                    </div>
                </div>
        ))}
    </div>

    <div class="toast" id="toast"></div>

    <script is:inline>
        const toast = document.getElementById('toast');

        function showToast(msg) {
            toast.textContent = msg;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 2500);
        }

        document.querySelectorAll('.cert-card').forEach(card => {
            card.addEventListener('click', () => {
                const url      = card.dataset.url;
                const copyCode = card.dataset.copy;

                if (copyCode) {
                    navigator.clipboard.writeText(copyCode).then(() => {
                        showToast('✓ Code "' + copyCode + '" copied — paste it on the page!');
                    }).catch(() => {
                        showToast('⚠ Could not copy — code: ' + copyCode);
                    });
                }

                window.open(url, '_blank', 'noopener');
            });
        });
    </script>
</Layout>