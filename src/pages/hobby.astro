---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hobby" current={`/hobby/`}>

  <div class="page-header">
    <div class="eyebrow" data-en="// after hours" data-pl="// po godzinach">// po godzinach</div>
    <h1 data-en="Hobby" data-pl="Zainteresowania">Zainteresowania</h1>
    <p data-en="What keeps me curious." data-pl="Co napędza moją ciekawość">
      What keeps me curious when the laptop lid is closed.
    </p>
  </div>

  <div class="hobby-grid">

    <!-- PSYCHOLOGY -->
    <div class="hobby-card">
      <div class="icon">
        <svg viewBox="0 0 24 24"><path fill="currentColor" d="M9 2a4 4 0 0 0-4 4v1a3 3 0 0 0 0 6v1a4 4 0 0 0 4 4h2v2h2v-2h2a4 4 0 0 0 4-4v-1a3 3 0 0 0 0-6V6a4 4 0 0 0-4-4z"/></svg>
      </div>
      <h3 data-en="Psychology" data-pl="Psychologia">Psychology</h3>
      <p data-en="Fascinated by social psychology, famous experiments, and the inner workings of the human mind."
         data-pl="Fascynuje mnie psychologia społeczna i działanie ludzkiego umysłu.">
        Fascinated by social psychology, famous experiments, and the inner workings of the human mind.
      </p>
    </div>

    <!-- ASTRONOMY -->
    <div class="hobby-card">
      <div class="icon">
        <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 2l1.5 4.5L18 8l-4.5 1.5L12 14l-1.5-4.5L6 8l4.5-1.5z"/></svg>
      </div>
      <h3>Astronomy</h3>
      <p>Contemplating the mysteries of the cosmos and fundamental laws of the universe.</p>
    </div>

    <!-- BIOLOGY -->
    <div class="hobby-card">
      <div class="icon">
        <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 2c3 3 3 7 0 10s-3 7 0 10m0-20c-3 3-3 7 0 10s3 7 0 10"/></svg>
      </div>
      <h3>Biology</h3>
      <p>Interest in life complexity — from cells to ecosystems.</p>
    </div>

    <!-- SPORT -->
    <div class="hobby-card">
      <div class="icon">
        <svg viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10" stroke="currentColor" fill="none"/>
          <path d="M2 12a10 10 0 0 0 20 0" stroke="currentColor" fill="none"/>
        </svg>
      </div>
      <h3>Sports & Fitness</h3>
      <p>Tennis, gym, cycling. Previously football, karate, table tennis.</p>
    </div>

    <!-- MOUNTAINS -->
    <div class="hobby-card">
      <div class="icon">
        <svg viewBox="0 0 24 24"><path fill="currentColor" d="M3 20l7-12l4 6l3-4l4 10z"/></svg>
      </div>
      <h3>Mountains</h3>
      <p>Hiking in Tatras and Alps. Peace and perspective.</p>
    </div>

    <!-- WILDLIFE -->
    <div class="hobby-card">
      <div class="icon">
        <svg viewBox="0 0 24 24"><path fill="currentColor" d="M2 12c5-4 10-4 20 0c-5 4-10 4-20 0"/></svg>
      </div>
      <h3>Wildlife</h3>
      <p>Birds, animals, nature observation, mindfulness.</p>
    </div>

    <!-- COOKING -->
    <div class="hobby-card">
      <div class="icon">
        <svg viewBox="0 0 24 24">
          <circle cx="10" cy="10" r="6" stroke="currentColor" fill="none"/>
          <path d="M14 14l6 6" stroke="currentColor"/>
        </svg>
      </div>
      <h3>Culinary Arts</h3>
      <p>Thai, Polish, Italian. Big seafood fan.</p>
    </div>

    <!-- CITY -->
    <div class="hobby-card">
      <div class="icon">
        <svg viewBox="0 0 24 24">
          <path fill="currentColor" d="M4 8h14v6a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4z"/>
          <path d="M18 10h2a2 2 0 0 1 0 4h-2" stroke="currentColor" fill="none"/>
        </svg>
      </div>
      <h3>City Life</h3>
      <p>Exploring Kraków, coffee, hidden spots.</p>
    </div>

    <!-- GAMING -->
    <div class="hobby-card">
      <div class="icon">
        <svg viewBox="0 0 24 24"><path fill="currentColor" d="M7 8h10l2 4l-2 4H7l-2-4z"/></svg>
      </div>
      <h3>Gaming</h3>
      <p>RPG, storytelling, PC + consoles.</p>
    </div>

    <!-- MUSIC -->
    <div class="hobby-card">
      <div class="icon">
        <svg viewBox="0 0 24 24">
          <path fill="currentColor" d="M12 2a4 4 0 0 1 4 4v6a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4"/>
          <path d="M8 18h8" stroke="currentColor"/>
        </svg>
      </div>
      <h3>Music & Events</h3>
      <p>Hip-hop, concerts, live events.</p>
    </div>

    <!-- TECH -->
    <div class="hobby-card">
      <div class="icon">
        <svg viewBox="0 0 24 24">
          <path fill="currentColor" d="M4 4h16v12H4z"/>
          <path d="M2 20h20" stroke="currentColor"/>
        </svg>
      </div>
      <h3>Tech Curiosity</h3>
      <p>Understanding hardware and systems behind code.</p>
    </div>

  </div>

</Layout>