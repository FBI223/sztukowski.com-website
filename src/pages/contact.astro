---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" current={`/contact/`}>

    <div class="page-header">
        <div class="eyebrow">// contact</div>

        <h1 data-en="Contact" data-pl="Kontakt">Contact</h1>

        <p
                data-en="Open to collaboration, research, or engineering opportunities."
                data-pl="Otwartość na współpracę, projekty badawcze i inżynieryjne."
        >
            Open to collaboration, research, or engineering opportunities.
        </p>
    </div>

    <div class="hbox">
  <span
          data-en="If you're interested in working together, feel free to reach out."
          data-pl="Jeśli jesteś zainteresowany współpracą — zapraszam do kontaktu."
  >
    If you're interested in working together, feel free to reach out.
  </span>
    </div>

    <button class="btn btn-primary" id="contact-toggle"
            data-en="Show Contact"
            data-pl="Pokaż kontakt">
        Show Contact
    </button>

    <div class="contact-grid hidden" id="contact-grid">

        <!-- EMAIL -->
        <div class="contact-tile copy" data-copy="sztukowski@vp.pl">
            <div class="icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <rect x="3" y="5" width="18" height="14" rx="2"/>
                    <path d="M3 7l9 6 9-6"/>
                </svg>
            </div>
            <div class="label">EMAIL</div>
            <div class="value">sztukowski@vp.pl</div>
        </div>

        <!-- PHONE -->
        <div class="contact-tile copy" data-copy="728700706">
            <div class="icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2 4.2 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1.8.3 1.6.6 2.3a2 2 0 0 1-.4 2L8 9a16 16 0 0 0 6 6l1-1.2a2 2 0 0 1 2-.4c.7.3 1.5.5 2.3.6A2 2 0 0 1 22 16.9z"/>
                </svg>
            </div>
            <div class="label">PHONE</div>
            <div class="value">+48 728 700 706</div>
        </div>

        <!-- LINKEDIN -->
        <a href="https://www.linkedin.com/in/marcin-sztukowski-a01a8a35a"
           target="_blank"
           class="contact-tile">
            <div class="icon">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M4 3a2 2 0 100 4 2 2 0 000-4zm1 6H3v12h2V9zm4 0h-2v12h2v-6c0-3 4-3 4 0v6h2v-7c0-5-6-4.8-6-2.3V9z"/>
                </svg>
            </div>
            <div class="label">LINKEDIN</div>
            <div class="value"
                 data-en="Open profile"
                 data-pl="Otwórz profil">
                Open profile
            </div>
        </a>

        <!-- GITHUB -->
        <a href="https://github.com/FBI223"
           target="_blank"
           class="contact-tile">
            <div class="icon">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2a10 10 0 00-3.2 19.5c.5.1.7-.2.7-.5v-1.8c-2.8.6-3.4-1.3-3.4-1.3-.4-1-.9-1.2-.9-1.2-.8-.5.1-.5.1-.5.9.1 1.4.9 1.4.9.8 1.3 2.1.9 2.6.7.1-.6.3-1 .6-1.3-2.2-.3-4.6-1.1-4.6-5a3.8 3.8 0 011-2.7c-.1-.3-.4-1.4.1-2.8 0 0 .8-.3 2.8 1a9.6 9.6 0 015 0c2-1.3 2.8-1 2.8-1 .5 1.4.2 2.5.1 2.8a3.8 3.8 0 011 2.7c0 3.9-2.4 4.7-4.7 5 .3.3.6.8.6 1.6v2.3c0 .3.2.6.7.5A10 10 0 0012 2z"/>
                </svg>
            </div>
            <div class="label">GITHUB</div>
            <div class="value">FBI223</div>
        </a>

    </div>

    <script is:inline>
        const toggle = document.getElementById('contact-toggle');
        const grid   = document.getElementById('contact-grid');

        toggle.addEventListener('click', () => {
            grid.classList.toggle('hidden');
        });

        /* COPY (EMAIL + PHONE) */
        document.querySelectorAll('.copy').forEach(el => {
            el.addEventListener('click', () => {
                navigator.clipboard.writeText(el.dataset.copy);

                el.classList.add('copied');

                const label = document.createElement('div');
                label.className = 'copy-label';

                const lang = document.documentElement.getAttribute('data-lang');
                label.textContent = lang === 'pl' ? 'Skopiowano' : 'Copied';

                el.appendChild(label);

                setTimeout(() => {
                    el.classList.remove('copied');
                    label.remove();
                }, 1200);
            });
        });
    </script>

</Layout>