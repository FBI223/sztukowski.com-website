---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" current={`/contact/`}>

    <div class="page-header">
        <div class="eyebrow">// get in touch</div>
        <h1>Contact</h1>
        <p>Click to reveal contact details.</p>
    </div>

    <div class="contact-reveal">
        <button id="reveal-btn" class="btn btn-primary">
            SHOW CONTACT
        </button>
    </div>

    <div id="contact-grid" class="contact-grid hidden">

        <!-- EMAIL -->
        <div class="contact-tile copy" data-copy="sztukowski@vp.pl">
            <div class="icon">
                <svg viewBox="0 0 24 24"><path fill="currentColor" d="M20 4H4a2 2 0 0 0-2 2v.01L12 13l10-6.99V6a2 2 0 0 0-2-2m0 4.25l-8 5l-8-5V18a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2z"/></svg>
            </div>
            <div class="label">EMAIL</div>
            <div class="value">sztukowski@vp.pl</div>
        </div>

        <!-- PHONE -->
        <a class="contact-tile" href="tel:728700706">
            <div class="icon">
                <svg viewBox="0 0 24 24"><path fill="currentColor" d="M6.6 10.8a15 15 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24a11.4 11.4 0 0 0 3.6.6a1 1 0 0 1 1 1V21a1 1 0 0 1-1 1A17 17 0 0 1 2 5a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1a11.4 11.4 0 0 0 .6 3.6a1 1 0 0 1-.25 1z"/></svg>
            </div>
            <div class="label">PHONE</div>
            <div class="value">728 700 706</div>
        </a>

        <!-- GITHUB -->
        <a class="contact-tile" href="https://github.com/FBI223" target="_blank">
            <div class="icon">
                <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 2A10 10 0 0 0 2 12c0 4.4 2.9 8.1 6.9 9.4c.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.3-3.4-1.3c-.4-1-.9-1.3-.9-1.3c-.7-.5.1-.5.1-.5c.8.1 1.2.8 1.2.8c.7 1.2 1.9.9 2.3.7c.1-.5.3-.9.5-1.1c-2.2-.2-4.5-1.1-4.5-5a3.9 3.9 0 0 1 1-2.7a3.6 3.6 0 0 1 .1-2.6s.8-.3 2.7 1a9.4 9.4 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1a3.6 3.6 0 0 1 .1 2.6a3.9 3.9 0 0 1 1 2.7c0 3.9-2.3 4.7-4.5 5c.3.2.6.7.6 1.5v2.3c0 .3.2.6.7.5A10 10 0 0 0 22 12A10 10 0 0 0 12 2"/></svg>
            </div>
            <div class="label">GITHUB</div>
            <div class="value">github.com/FBI223</div>
        </a>

        <!-- LINKEDIN -->
        <a class="contact-tile" href="https://www.linkedin.com/in/marcin-sztukowski-a01a8a35a" target="_blank">
            <div class="icon">
                <svg viewBox="0 0 24 24"><path fill="currentColor" d="M6.94 6.5a1.94 1.94 0 1 1 0-3.88a1.94 1.94 0 0 1 0 3.88M4 8h6v12H4zm10 0h5.6v1.7h.1c.8-1.4 2.6-2.9 5.3-2.9c5.7 0 6.7 3.7 6.7 8.5V20h-6v-5.9c0-1.4 0-3.2-2-3.2s-2.3 1.5-2.3 3.1V20h-6z"/></svg>
            </div>
            <div class="label">LINKEDIN</div>
            <div class="value">marcin-sztukowski</div>
        </a>

    </div>

</Layout>

<script is:inline>
    const btn = document.getElementById('reveal-btn');
    const grid = document.getElementById('contact-grid');

    btn.addEventListener('click', () => {
        grid.classList.toggle('hidden');
        btn.textContent = grid.classList.contains('hidden')
            ? 'SHOW CONTACT'
            : 'HIDE CONTACT';
    });

    // COPY EMAIL
    document.querySelectorAll('.copy').forEach(el => {
        el.addEventListener('click', () => {
            const text = el.dataset.copy;
            navigator.clipboard.writeText(text);

            el.classList.add('copied');
            el.querySelector('.value').textContent = 'Copied!';

            setTimeout(() => {
                el.classList.remove('copied');
                el.querySelector('.value').textContent = text;
            }, 1200);
        });
    });
</script>