<Layout title="Courses" current="/courses">

<div class="page-header">
  <div class="eyebrow" data-en="// academic curriculum" data-pl="// program akademicki">// academic curriculum</div>
  <h1 data-en="Courses"  data-pl="Kursy">Courses</h1>
