<Layout title="Courses" current="/courses">

<div class="page-header">
  <div class="eyebrow">// academic curriculum</div>
  <h1>Courses</h1>
  <p>Full course list from BSc and MSc Computer Science at Jagiellonian University.</p>
</div>

<div class="legend">
  <div class="legend-item"><span class="dot dot-done"></span> Completed</div>
  <div class="legend-item"><span class="dot dot-ongoing"></span> Ongoing</div>
</div>

