---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Experience" current={`/experience/`}>

    <div class="page-header">
        <div class="eyebrow" data-en="// professional journey" data-pl="// droga zawodowa">// professional journey</div>
        <h1 data-en="Experience & Education" data-pl="Doświadczenie i Edukacja">Experience & Education</h1>
        <p data-en="Bridging academic research with practical system engineering and infrastructure management."
           data-pl="Łączenie badań akademickich z praktyczną inżynierią systemów i zarządzaniem infrastrukturą.">
            Bridging academic research with practical system engineering and infrastructure management.
        </p>
    </div>



    <!-- EDUCATION SECTION -->
    <div class="sec-label" data-en="Education" data-pl="Wykształcenie">Education</div>
    <div class="timeline">
        <div class="tl-item">
            <div class="date">Jul 2025 – present</div>
            <h4 data-en="MSc Computer Science" data-pl="Magisterium Informatyka">MSc Computer Science</h4>
            <div class="org" data-en="Jagiellonian University, Kraków" data-pl="Uniwersytet Jagielloński, Kraków">Jagiellonian University, Kraków</div>
            <p data-en="Machine learning · bioinformatics · deep learning · quantum cryptography · networks · drug design ML" data-pl="Uczenie maszynowe · bioinformatyka · deep learning · kryptografia kwantowa · sieci · ML w projektowaniu leków">Machine learning · bioinformatics · deep learning · quantum cryptography · networks · drug design ML</p>
        </div>
        <div class="tl-item">
            <div class="date">Oct 2021 – Jul 2025</div>
            <h4 data-en="BSc Computer Science" data-pl="Licencjat Informatyka">BSc Computer Science</h4>
            <div class="org" data-en="Jagiellonian University, Kraków" data-pl="Uniwersytet Jagielloński, Kraków">Jagiellonian University, Kraków</div>
            <p data-en="Algorithms · numerical methods · software engineering · functional programming · networks · databases" data-pl="Algorytmy · metody numeryczne · inżynieria oprogramowania · programowanie funkcyjne · sieci · bazy danych">Algorithms · numerical methods · software engineering · functional programming · networks · databases</p>
        </div>
        <div class="tl-item">
            <div class="date">Oct 2019 – Sep 2021</div>
            <h4 data-en="BSc Economics (incomplete)" data-pl="Licencjat Ekonomia">BSc Economics</h4>
            <div class="org" data-en="University of Warsaw, Warsaw" data-pl="Uniwersytet Warszawski, Warszawa">University of Warsaw, Warsaw</div>
            <p data-en="Transferred to pursue CS full-time." data-pl="Zmiana studiów, aby w pełni poświęcić się informatyce.">Transferred to pursue CS full-time.</p>
        </div>
        <div class="tl-item">
            <div class="date">Sep 2016 – May 2019</div>
            <h4 data-en="High School — Matura" data-pl="Liceum — Matura">High School — Matura</h4>
            <div class="org">VILO, Białystok</div>
        </div>
    </div>

    <!-- WORK EXPERIENCE SECTION -->
    <div class="sec-label" data-en="Work Experience" data-pl="Doświadczenie Zawodowe">Work Experience</div>

    <div class="work-card">
        <div class="work-header">
            <div class="work-title" data-en="IT Support / Lead Server Administrator" data-pl="Wsparcie IT / Główny Administrator Serwerów">IT Support / Lead Server Administrator</div>
            <div class="work-date">Jan 2022 – present</div>
        </div>
        <div class="work-org">J&J Financial Associates LLC · New Britain, CT, USA (zdalnie)</div>
        <div class="work-body"><ul>
            <li data-en="Remote support for computing systems, VoIP, printers, email and data server" data-pl="Zdalne wsparcie systemów komputerowych, VoIP, drukarek, email i serwera danych">Remote support for computing systems, VoIP, printers, email and data server</li>
            <li data-en="Hardware/software upgrades and system optimizations" data-pl="Modernizacje sprzętu/oprogramowania i optymalizacje systemu">Hardware/software upgrades and system optimizations</li>
        </ul></div>
    </div>

    <div class="work-card">
        <div class="work-header">
            <div class="work-title" data-en="Network Engineer" data-pl="Inżynier Sieci">Network Engineer</div>
            <div class="work-date">Dec 2024 – Jan 2025</div>
        </div>
        <div class="work-org">New Britain, CT, USA</div>
        <div class="work-body"><ul>
            <li data-en="Complete overhaul of building IT and network infrastructure" data-pl="Całkowita przebudowa infrastruktury IT i sieciowej budynku">Complete overhaul of building IT and network infrastructure</li>
            <li data-en="Routers, switches, patch panels, IP cameras, new cabling" data-pl="Routery, switche, panele krosownicze, kamery IP, nowe okablowanie">Routers, switches, patch panels, IP cameras, new cabling</li>
            <li data-en="VoIP server, VLAN segmentation, traffic routing, public IPs per office" data-pl="Serwer VoIP, segmentacja VLAN, routing ruchu, publiczne IP per biuro">VoIP server, VLAN segmentation, traffic routing, public IPs per office</li>
        </ul></div>
    </div>

    <div class="work-card">
        <div class="work-header">
            <div class="work-title" data-en="Mathematics Tutor" data-pl="Korepetytor z Matematyki">Mathematics Tutor</div>
            <div class="work-date">Jan 2022 – present</div>
        </div>
        <div class="work-org" data-en="Private" data-pl="Prywatnie">Private</div>
        <div class="work-body" data-en="High school mathematics — core concepts and Matura exam preparation." data-pl="Matematyka liceum — podstawy i przygotowanie do matury.">High school mathematics — core concepts and Matura exam preparation.</div>
    </div>

    <div class="work-card">
        <div class="work-header">
            <div class="work-title" data-en="Tax Office Assistant" data-pl="Asystent w Biurze Podatkowym">Tax Office Assistant</div>
            <div class="work-date">Jun 2022 – Jan 2023</div>
        </div>
        <div class="work-org">J&J Financial Associates LLC · New Britain, CT, USA</div>
        <div class="work-body" data-en="Income tax returns, IRS and insurance audits, invoice issuance, IT support." data-pl="Zeznania podatkowe, audyty IRS i ubezpieczeniowe, wystawianie faktur, wsparcie IT.">Income tax returns, IRS and insurance audits, invoice issuance, IT support.</div>
    </div>

    <div class="work-card">
        <div class="work-header">
            <div class="work-title" data-en="Seasonal Tax Office Assistant" data-pl="Sezonowy Asystent w Biurze Podatkowym">Seasonal Tax Office Assistant</div>
            <div class="work-date">Jul 2016 – Sep 2020</div>
        </div>
        <div class="work-org">J&J Financial Associates LLC · New Britain, CT, USA</div>
        <div class="work-body" data-en="Tax filing, document proofreading, sales and property tax, IT support." data-pl="Wypełnianie zeznań, sprawdzanie dokumentów, podatek od sprzedaży i nieruchomości, wsparcie IT.">Tax filing, document proofreading, sales and property tax, IT support.</div>
    </div>

</Layout>