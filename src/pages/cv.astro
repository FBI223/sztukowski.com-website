---
import Layout from '../layouts/Layout.astro';
const BASE = '/sztukowski.com-website';
---

<Layout title="CV" current={`${BASE}/cv/`}>
<style>
  .cv-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .pdf-frame {
    width: 100%;
    height: 80vh;
    min-height: 500px;
    border: 1px solid var(--border);
    border-radius: var(--r2);
    background: var(--bg2);
  }
</style>

  <div class="page-header">
    <div class="eyebrow" data-en="// curriculum vitae" data-pl="// życiorys">// curriculum vitae</div>
    <h1 data-en="CV" data-pl="CV">CV</h1>
    <p
        data-en="Full curriculum vitae — view inline or download as PDF."
        data-pl="Pełne CV — przeglądaj na stronie lub pobierz jako PDF.">
      Full curriculum vitae — view inline or download as PDF.
    </p>
  </div>

  <div class="cv-actions">
    <a
        href={`${BASE}/cv.pdf`}
        download
        class="btn btn-primary"
        data-en="Download PDF ↓"
        data-pl="Pobierz PDF ↓">
      Download PDF ↓
    </a>

    <a
        href={`${BASE}/cv.pdf`}
        target="_blank"
        rel="noopener"
        class="btn btn-secondary"
        data-en="Open in new tab ↗"
        data-pl="Otwórz w nowej karcie ↗">
      Open in new tab ↗
    </a>
  </div>

<embed src={`${BASE}/cv.pdf`}type="application/pdf" class="pdf-frame" />

</Layout>
