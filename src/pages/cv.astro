---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CV" current="/cv">
<style>
  .cv-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .pdf-frame {
    width: 100%;
    height: 80vh;
    min-height: 500px;
    border: 1px solid var(--border);
    border-radius: var(--r2);
    background: var(--bg2);
  }
</style>

<div class="page-header">
  <div class="eyebrow">// curriculum vitae</div>
  <h1>CV</h1>
  <p>Full curriculum vitae — view inline or download as PDF.</p>
</div>

<div class="cv-actions">
  <a href="/cv.pdf" download class="btn btn-primary">Download PDF ↓</a>
  <a href="/cv.pdf" target="_blank" rel="noopener" class="btn btn-secondary">Open in new tab ↗</a>
</div>

<embed src="/cv.pdf" type="application/pdf" class="pdf-frame" />

</Layout>
