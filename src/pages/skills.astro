---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Skills" current="/skills">

<div class="page-header">
  <div class="eyebrow">// technical profile</div>
  <h1>Skills</h1>
  <p>Languages, frameworks, domains and tools I work with regularly.</p>
</div>

<div class="domain">
  <div class="domain-title">Programming Languages</div>
  <div class="skill-grid">
    <div class="skill-card">
      <div class="cat">Primary</div>
      <div class="items">Python<br>C++<br>Java<br>C#</div>
    </div>
    <div class="skill-card">
      <div class="cat">Mobile & Systems</div>
      <div class="items">Swift<br>C<br>Bash<br>Unix shell</div>
    </div>
    <div class="skill-card">
      <div class="cat">Functional & Other</div>
      <div class="items">Haskell<br>SQL<br>HTML / CSS<br>JavaScript</div>
    </div>
  </div>
</div>

<div class="domain">
  <div class="domain-title">Machine Learning & AI</div>
  <div class="skill-grid">
    <div class="skill-card">
      <div class="cat">Frameworks</div>
      <div class="items">PyTorch<br>TensorFlow<br>scikit-learn<br>CoreML (iOS)</div>
    </div>
    <div class="skill-card">
      <div class="cat">Architectures</div>
      <div class="items">CNN / RNN / LSTM<br>Transformer<br>Diffusion models<br>Multi-task learning</div>
    </div>
    <div class="skill-card">
      <div class="cat">Techniques</div>
      <div class="items">LoRA fine-tuning<br>3D Gaussian Splatting<br>Inpainting<br>On-device inference</div>
    </div>
    <div class="skill-card">
      <div class="cat">Data & Analysis</div>
      <div class="items">pandas · numpy<br>matplotlib<br>Wavelet denoising<br>WFDB format</div>
    </div>
  </div>
</div>

<div class="domain">
  <div class="domain-title">Bioinformatics & Drug Design</div>
  <div class="skill-grid">
    <div class="skill-card">
      <div class="cat">Genomics</div>
      <div class="items">VCF / BAM<br>GATK · samtools<br>Variant calling<br>DNA pipelines</div>
    </div>
    <div class="skill-card">
      <div class="cat">Signal Processing</div>
      <div class="items">ECG analysis<br>QRS / P / T detection<br>Resampling<br>Normalization</div>
    </div>
    <div class="skill-card">
      <div class="cat">Drug ML — ADMET</div>
      <div class="items">MTL prediction<br>Molecular descriptors<br>Pharmacokinetics<br>MLDD 2026</div>
    </div>
  </div>
</div>

<div class="domain">
  <div class="domain-title">Embedded & Mobile</div>
  <div class="skill-grid">
    <div class="skill-card">
      <div class="cat">Embedded</div>
      <div class="items">Arduino<br>ESP32<br>BLE / Bluetooth<br>Sensor integration</div>
    </div>
    <div class="skill-card">
      <div class="cat">iOS Development</div>
      <div class="items">SwiftUI<br>CoreBluetooth<br>CoreML<br>WFDB storage</div>
    </div>
    <div class="skill-card">
      <div class="cat">Game Dev</div>
      <div class="items">Godot Engine<br>C# scripting<br>Design patterns<br>FSM / OOP</div>
    </div>
  </div>
</div>

<div class="domain">
  <div class="domain-title">Computer Networks</div>
  <div class="skill-grid">
    <div class="skill-card">
      <div class="cat">Protocols & Routing</div>
      <div class="items">IPv4 / IPv6<br>VPN<br>Routing protocols<br>VLAN segmentation</div>
    </div>
    <div class="skill-card">
      <div class="cat">Infrastructure</div>
      <div class="items">VoIP / SIP<br>Switches · patch panels<br>IP cameras<br>Server admin</div>
    </div>
    <div class="skill-card">
      <div class="cat">Security & Analysis</div>
      <div class="items">Wireshark<br>Network security<br>Traffic analysis<br>Firewall config</div>
    </div>
  </div>
</div>

<div class="domain">
  <div class="domain-title">Cryptography</div>
  <div class="skill-grid">
    <div class="skill-card">
      <div class="cat">Classical</div>
      <div class="items">Symmetric encryption<br>RSA / ECC<br>Hash functions<br>PKI</div>
    </div>
    <div class="skill-card">
      <div class="cat">Post-Quantum & Quantum</div>
      <div class="items">Lattice-based crypto<br>CRYSTALS-Kyber<br>QKD · BB84<br>NIST PQC</div>
    </div>
  </div>
</div>

<div class="domain">
  <div class="domain-title">Tools & Systems</div>
  <div class="skill-grid">
    <div class="skill-card">
      <div class="cat">Dev Tools</div>
      <div class="items">Git · GitHub<br>WebStorm · VS Code<br>Xcode<br>Jupyter</div>
    </div>
    <div class="skill-card">
      <div class="cat">Systems</div>
      <div class="items">Linux / Unix<br>Bash scripting<br>Docker (basics)<br>SSH · remote admin</div>
    </div>
    <div class="skill-card">
      <div class="cat">Languages</div>
      <div class="items">Polish — native<br>English — C1</div>
    </div>
  </div>
</div>

</Layout>
